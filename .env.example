# 1. Google Sheets & Apps Script Configuration
APPS_SCRIPT_URL=your_google_apps_script_web_app_url_here
SHEET_URL=your_google_sheet_url_here
SHEET_NAME=your_default_sheet_name_here

# 2. Telegram Bot Configuration (For price change notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 3. Haravan Integration Configuration
HARAVAN_SHOP_URL=your_haravan_shop_domain_here
HARAVAN_ACCESS_TOKEN=your_haravan_access_token_here
